# Get your sandbox API key from https://developer.minepi.com
# Under your app → "API Keys" → copy the Server-side API key
PI_API_KEY=your_sandbox_api_key_here

# Pi Network API base URL — same endpoint for both sandbox and mainnet;
# sandbox vs mainnet is determined by your API key type and Pi.init({ sandbox })
PI_API_BASE=https://api.minepi.com/v2

PORT=3001
